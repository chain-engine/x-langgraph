# ========== 应用配置 ==========
APP_NAME=x-langgraph
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
APP_DEBUG=true

# ========== 服务器配置 ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_RELOAD=true

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/x-langgraph.log

# ========== CORS配置 ==========
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=*

# ========== 限流配置 ==========
RATE_LIMIT_ENABLED=true

# ========== 业务数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=

# ========== Redis配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== LLM配置 ==========
TEMPERATURE=0.0
STRUCTURED=false

# ========== DeepSeek配置 ==========
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat

# ========== 豆包配置 ==========
DOUBAO_API_KEY=
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_NAME=

# ========== 阿里云百炼配置 ==========
ALIYUN_API_KEY=
ALIYUN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL_NAME=qwen-turbo

# ========== 第三方API配置 ==========
AMAP_API_KEY=
SEARCH_API_KEY=
SEARCH_API_URL=
API_KEY=
